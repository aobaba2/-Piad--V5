{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Dish categories",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name"
        }
      },
      "required": ["name"]
    },
    "Dish": {
      "title": "Dish",
      "description": "Restaurant dishes",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Dish name"
        },
        "price": {
          "type": "number",
          "description": "Dish price"
        },
        "image": {
          "type": "string",
          "description": "Image URL"
        },
        "category": {
          "type": "string",
          "description": "Category name"
        },
        "description": {
          "type": "string",
          "description": "Dish description"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dish tags"
        },
        "isRecommended": {
          "type": "boolean",
          "description": "Whether the dish is recommended"
        },
        "order": {
          "type": "number",
          "description": "Display order of the dish"
        }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "gridColumns": {
          "type": "number",
          "description": "Number of columns for dish cards on the homepage"
        }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dishId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "served", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tableNumber", "items", "totalPrice", "status", "createdAt"]
    }
  },
  "firestore": {
    "/categories": {
      "schema": "Category",
      "description": "Collection of dish categories"
    },
    "/dishes": {
      "schema": "Dish",
      "description": "Collection of dishes"
    },
    "/settings": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
