{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Dish categories",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name"
        }
      },
      "required": ["name"]
    },
    "Dish": {
      "title": "Dish",
      "description": "Restaurant dishes",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Dish name"
        },
        "price": {
          "type": "number",
          "description": "Dish price"
        },
        "image": {
          "type": "string",
          "description": "Image URL"
        },
        "category": {
          "type": "string",
          "description": "Category name"
        },
        "description": {
          "type": "string",
          "description": "Dish description"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dish tags"
        },
        "isRecommended": {
          "type": "boolean",
          "description": "Whether the dish is recommended"
        },
        "order": {
          "type": "number",
          "description": "Display order of the dish"
        }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "gridColumns": {
          "type": "number",
          "description": "Number of columns for dish cards on the homepage"
        }
      }
    }
  },
  "firestore": {
    "/categories": {
      "schema": "Category",
      "description": "Collection of dish categories"
    },
    "/dishes": {
      "schema": "Dish",
      "description": "Collection of dishes"
    },
    "/settings": {
      "schema": "Settings",
      "description": "Global settings document"
    }
  }
}
