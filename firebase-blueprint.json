{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Dish categories",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name"
        }
      },
      "required": ["name"]
    },
    "Dish": {
      "title": "Dish",
      "description": "Restaurant dishes",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Dish name (default/Chinese)"
        },
        "name_en": {
          "type": "string",
          "description": "Dish name in English"
        },
        "name_ko": {
          "type": "string",
          "description": "Dish name in Korean"
        },
        "price": {
          "type": "number",
          "description": "Dish price"
        },
        "image": {
          "type": "string",
          "description": "Image URL"
        },
        "category": {
          "type": "string",
          "description": "Category name"
        },
        "description": {
          "type": "string",
          "description": "Dish description"
        },
        "description_en": {
          "type": "string",
          "description": "Dish description in English"
        },
        "description_ko": {
          "type": "string",
          "description": "Dish description in Korean"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dish tags"
        },
        "isRecommended": {
          "type": "boolean",
          "description": "Whether the dish is recommended"
        },
        "isSoldOut": {
          "type": "boolean",
          "description": "Whether the dish is sold out"
        },
        "order": {
          "type": "number",
          "description": "Display order of the dish"
        },
        "stock": {
          "type": "number",
          "description": "Inventory stock level"
        }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "currency": {
          "type": "string",
          "enum": ["KRW", "CNY", "USD"],
          "description": "Current currency"
        },
        "language": {
          "type": "string",
          "enum": ["zh", "en", "ko"],
          "description": "Default language"
        },
        "restaurantName": {
          "type": "string",
          "description": "Name of the restaurant"
        }
      }
    },
    "Table": {
      "title": "Table",
      "description": "Restaurant tables and QR sessions",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "active"] },
        "sessionToken": { "type": "string" },
        "lastOrderAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dishId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "served", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "sessionToken": { "type": "string" }
      },
      "required": ["tableNumber", "items", "totalPrice", "status", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Restaurant staff members",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["owner", "manager", "waiter"] }
      },
      "required": ["email", "role"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Homepage carousel banners",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image": { "type": "string" },
        "dishId": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "image", "order"]
    },
    "SuperAdmin": {
      "title": "SuperAdmin",
      "description": "Super administrator account for direct login",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["owner"] }
      },
      "required": ["username", "password", "role"]
    }
  },
  "firestore": {
    "/categories": {
      "schema": "Category",
      "description": "Collection of dish categories"
    },
    "/dishes": {
      "schema": "Dish",
      "description": "Collection of dishes"
    },
    "/settings": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/staff": {
      "schema": "Staff",
      "description": "Collection of staff members"
    },
    "/banners": {
      "schema": "Banner",
      "description": "Collection of homepage carousel banners"
    },
    "/super_admins": {
      "schema": "SuperAdmin",
      "description": "Collection of super administrator accounts"
    }
  }
}
